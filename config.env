# ============================================
# LolKernel Build Configuration
# ============================================

# Project Info
PROJECT_NAME="LolKernel"
PROJECT_VERSION="1.0"
PROJECT_AUTHOR="bradarshome"

# Kernel Versions to Build
# Supported: "5.10" (Android 12) | "6.6" (Android 15)
KERNEL_VERSIONS=("5.10" "6.6")

# GKI Kernel Source (Google AOSP)
# Branches: common-android12-5.10-lts | common-android15-6.6
AOSP_MANIFEST_URL="https://android.googlesource.com/kernel/manifest"

# KernelSU Configuration
# Universal driver - compatible with all forks
KSU_REPO="https://github.com/tiann/KernelSU.git"
KSU_BRANCH="main"
KSU_DRIVER_PATH="drivers/kernelsu"

# SUSFS Configuration
SUSFS_REPO="https://gitlab.com/simonpunk/susfs4ksu.git"
# Branch di-map otomatis di apply_susfs.sh per kernel version

# SUSFS Userspace Module (included in AnyKernel3 zip)
SUSFS_MODULE_REPO="https://github.com/sidex15/susfs4ksu-module.git"
SUSFS_MODULE_BRANCH="main"
SUSFS_MODULE_VERSION="1.5.2"

# AnyKernel3 Configuration
AK3_REPO="https://github.com/osm0sis/AnyKernel3.git"
AK3_BRANCH="master"

# LolPerf Configuration (Smart Performance Manager)
LOLPERF_ENABLED="1"

# Build Configuration
BUILD_JOBS=$(nproc --all 2>/dev/null || echo "4")
LTO_MODE="thin"
BUILD_VARIANT="user"

# Output Configuration
OUTPUT_DIR="output"
ZIP_PREFIX="LolKernel"

# Device Compatibility
# Set to "1" to include device-specific patches
INCLUDE_DEVICE_PATCHES="0"

# Docker Configuration
DOCKER_IMAGE="lolkernel-builder"
DOCKER_TAG="latest"
